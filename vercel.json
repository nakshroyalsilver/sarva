{
  "rewrites": [
    {
      "source": "/product/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(WhatsApp|bot|facebookexternalhit|Twitterbot|LinkedInBot|TelegramBot|Slackbot).*"
        }
      ],
      "destination": "/api/bot"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}